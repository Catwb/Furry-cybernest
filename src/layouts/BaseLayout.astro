---
import config from "virtual:site-config";
import NavMenu from "../components/NavMenu.astro";
import { ViewTransitions } from "astro:transitions";
import { marked } from "marked";
import "../styles/globals.css";

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} | ${config.site.title}` : config.site.title;
const pageDesc = description || config.site.description;

const featConfig = JSON.stringify({
  showLanguage: config.codeBlock?.showLanguage,
  showLineNumbers: config.codeBlock?.showLineNumbers,
  enableCopy: config.codeBlock?.enableCopy,
  autoFoldThreshold: config.codeBlock?.autoFoldThreshold,
  lightbox: config.lightbox?.enabled,
  lightboxGallery: config.lightbox?.gallery,
  lightboxContent: config.lightbox?.content,
  lazyload: config.lazyload?.enabled,
});
---

<!doctype html>
<html lang={config.site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="author" content={config.site.author} />
    <title>{pageTitle}</title>

    <!-- Flash prevention + theme persistence: runs on every page load including View Transitions -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem("theme");
        if (t === "dark" || (!t && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>

    {config.fonts.cdn.filter((l: { head?: boolean }) => l.head).map((l: { href: string }) => <link rel="stylesheet" href={l.href} />)}
    {config.cdn.css.filter((l: { head?: boolean }) => l.head).map((l: { href: string }) => <link rel="stylesheet" href={l.href} />)}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={config.site.title} href="/rss.xml" />

    <script id="feat-config" type="application/json" set:html={featConfig} />

    <ViewTransitions />
    <meta name="astro-view-transitions-fallback" content="none" />
  </head>
  <body>
    <!-- Re-apply theme after every navigation (View Transitions may reset html class) -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem("theme");
        var html = document.documentElement;
        if (t === "dark" || (!t && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          if (!html.classList.contains("dark")) html.classList.add("dark");
        } else {
          html.classList.remove("dark");
        }
      })();
    </script>
    <div id="progress-bar" class="fixed top-0 left-0 h-[3px] bg-[var(--color-primary)] z-[9999] w-0 transition-[width] duration-200"></div>

    {config.cdn.js.map((l: { href: string }) => <script src={l.href}></script>)}
    {config.fonts.cdn.filter((l: { head?: boolean }) => !l.head).map((l: { href: string }) => <link rel="stylesheet" href={l.href} />)}
    {config.cdn.css.filter((l: { head?: boolean }) => !l.head).map((l: { href: string }) => <link rel="stylesheet" href={l.href} />)}

    <nav data-astro-transition-persist="nav"
         class="fixed top-4 left-1/2 -translate-x-1/2 z-50 max-w-3xl
                bg-[var(--color-card)]/95
                neon-border rounded-2xl px-4 md:px-6 py-3
                flex items-center justify-between"
         style="width: calc(100vw - 2rem)">
      <a href="/" class="font-heading text-lg neon-text-primary no-underline
                        hover:opacity-80 transition-all duration-300 shrink-0">
        {config.site.title}
      </a>

      <!-- Desktop nav -->
      <div id="desktop-nav" class="hidden md:flex items-center gap-6">
        <NavMenu items={config.nav} />
        <button id="theme-toggle-desktop" class="theme-toggle" aria-label="切换主题">
          <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="moon-icon hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>

      <!-- Mobile: hamburger + theme toggle -->
      <div class="flex md:hidden items-center gap-1">
        <button id="theme-toggle-mobile" class="theme-toggle" aria-label="切换主题">
          <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="moon-icon hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <button id="hamburger" class="relative w-9 h-9 flex items-center justify-center
                                      text-[var(--color-text)]/60 hover:text-[var(--color-secondary)]
                                      transition-colors duration-200" aria-label="菜单">
          <svg id="hamburger-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="close-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile drawer -->
    <div id="mobile-drawer"
         class="fixed inset-0 z-40 bg-[var(--color-bg)]/95 backdrop-blur-lg
                translate-x-full transition-transform duration-300 md:hidden">
      <div class="flex flex-col pt-20 px-6 overflow-y-auto h-full">
        <NavMenu items={config.nav} />
      </div>
    </div>

    {config.homepage.hero.background && config.homepage.hero.background !== "none" && (
      <div data-astro-transition-persist="bg" class="fixed inset-0 w-full h-full -z-10">
        <img src={config.homepage.hero.background} alt="" class="w-full h-full object-cover" />
      </div>
    )}

    <main class="min-h-screen pt-24 relative">
      <slot />
    </main>

    <footer class="neon-border border-x-0 border-b-0 mt-24 py-12">
      <div class="max-w-5xl mx-auto px-6">
        <div class="prose-footer max-w-lg mx-auto text-center">
          <Fragment set:html={marked.parse(config.footer.content || "")} />
        </div>
      </div>
    </footer>

    <script is:inline>
      /* Progress bar */
      var bar = document.getElementById("progress-bar");
      function startProgress() {
        bar.style.transition = "none";
        bar.style.width = "0%";
        requestAnimationFrame(function() {
          bar.style.transition = "width 0.4s ease";
          bar.style.width = "70%";
        });
      }
      function finishProgress() {
        bar.style.transition = "width 0.2s ease";
        bar.style.width = "100%";
        setTimeout(function() {
          bar.style.transition = "opacity 0.3s ease";
          bar.style.opacity = "0";
          setTimeout(function() {
            bar.style.transition = "none";
            bar.style.width = "0%";
            bar.style.opacity = "1";
          }, 300);
        }, 200);
      }

      function initHamburger() {
        var html = document.documentElement;
        var hamburger = document.getElementById("hamburger");
        var drawer = document.getElementById("mobile-drawer");
        var hamIcon = document.getElementById("hamburger-icon");
        var closeIcon = document.getElementById("close-icon");
        if (!hamburger || !drawer) return;
        /* Reset state on navigation */
        drawer.classList.add("translate-x-full");
        html.classList.remove("overflow-hidden");
        if (hamIcon) hamIcon.classList.remove("hidden");
        if (closeIcon) closeIcon.classList.add("hidden");
        hamburger.onclick = function() {
          var open = drawer.classList.toggle("translate-x-full");
          hamIcon.classList.toggle("hidden");
          closeIcon.classList.toggle("hidden");
          html.classList.toggle("overflow-hidden", !open);
        };
        drawer.onclick = function(e) {
          var link = e.target.closest(".nav-group > .nav-link");
          if (!link) return;
          var group = link.parentElement;
          if (!group) return;
          if (!group.querySelector(":scope > .nav-submenu")) return;
          e.preventDefault();
          group.classList.toggle("nav-open");
        };
      }

      function initThemeToggle() {
        function applyTheme(theme) {
          var dark = theme === "dark";
          var html = document.documentElement;
          if (dark) { html.classList.add("dark"); } else { html.classList.remove("dark"); }
          /* Sync icon state */
          [document.getElementById("theme-toggle-desktop"), document.getElementById("theme-toggle-mobile")].forEach(function(btn) {
            if (!btn) return;
            var sun = btn.querySelector(".sun-icon");
            var moon = btn.querySelector(".moon-icon");
            if (sun) sun.classList.toggle("hidden", dark);
            if (moon) moon.classList.toggle("hidden", !dark);
          });
        }
        function getPreferred() {
          var s = localStorage.getItem("theme");
          if (s) return s;
          return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        }
        /* Force-apply from localStorage every time (survive View Transitions) */
        applyTheme(getPreferred());
        /* Toggle: flip and save */
        function toggle() {
          var next = document.documentElement.classList.contains("dark") ? "light" : "dark";
          applyTheme(next);
          localStorage.setItem("theme", next);
        }
        /* Bind toggle buttons */
        [document.getElementById("theme-toggle-desktop"), document.getElementById("theme-toggle-mobile")].forEach(function(btn) {
          if (btn) btn.onclick = toggle;
        });
      }

      document.addEventListener("astro:page-load", function () {
        finishProgress();
        initHamburger();
        initThemeToggle();
        var els = document.querySelectorAll("[data-animate]");
        if (els.length && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          var obs = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("observed");
                obs.unobserve(entry.target);
              }
            });
          }, { threshold: 0.05 });
          els.forEach(function(el) { obs.observe(el); });
        }
      });

      document.addEventListener("astro:before-preparation", startProgress);
      initHamburger();
      initThemeToggle();
    </script>

    <script is:inline src="/scripts/features.js"></script>
  </body>
</html>
