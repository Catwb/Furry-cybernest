---
import config from "virtual:site-config";
import NavMenu from "../components/NavMenu.astro";
import { marked } from "marked";
import "../styles/globals.css";

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} | ${config.site.title}` : config.site.title;
const pageDesc = description || config.site.description;

const featConfig = JSON.stringify({
  showLanguage: config.codeBlock?.showLanguage,
  showLineNumbers: config.codeBlock?.showLineNumbers,
  enableCopy: config.codeBlock?.enableCopy,
  autoFoldThreshold: config.codeBlock?.autoFoldThreshold,
  lightbox: config.lightbox?.enabled,
  lightboxGallery: config.lightbox?.gallery,
  lightboxContent: config.lightbox?.content,
  lazyload: config.lazyload?.enabled,
});
---

<!doctype html>
<html lang={config.site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="author" content={config.site.author} />
    <title>{pageTitle}</title>

    {config.fonts.cdn.filter((l: { head?: boolean }) => l.head).map((l: { href: string }) => <link rel="stylesheet" href={l.href} />)}
    {config.cdn.css.filter((l: { head?: boolean }) => l.head).map((l: { href: string }) => <link rel="stylesheet" href={l.href} />)}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={config.site.title} href="/rss.xml" />

    <script id="feat-config" type="application/json" set:html={featConfig} />
  </head>
  <body>
    {config.cdn.js.map((l: { href: string }) => <script src={l.href}></script>)}
    {config.fonts.cdn.filter((l: { head?: boolean }) => !l.head).map((l: { href: string }) => <link rel="stylesheet" href={l.href} />)}
    {config.cdn.css.filter((l: { head?: boolean }) => !l.head).map((l: { href: string }) => <link rel="stylesheet" href={l.href} />)}

    <nav class="fixed top-4 left-1/2 -translate-x-1/2 z-50 max-w-3xl
                bg-[var(--color-surface)]/80 backdrop-blur-md
                neon-border rounded-2xl px-4 md:px-6 py-3
                flex items-center justify-between"
         style="width: calc(100vw - 2rem)">
      <a href="/" class="font-heading text-lg neon-text-primary no-underline
                        hover:opacity-80 transition-all duration-300 shrink-0">
        {config.site.title}
      </a>

      <!-- Desktop nav -->
      <div id="desktop-nav" class="hidden md:flex items-center gap-6">
        <NavMenu items={config.nav} />
      </div>

      <!-- Mobile: hamburger -->
      <div class="flex md:hidden items-center gap-2">
        <button id="hamburger" class="relative w-9 h-9 flex items-center justify-center
                                      text-[var(--color-text)]/60 hover:text-[var(--color-secondary)]
                                      transition-colors duration-200" aria-label="菜单">
          <svg id="hamburger-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="close-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile drawer -->
    <div id="mobile-drawer"
         class="fixed inset-0 z-40 bg-[var(--color-bg)]/95 backdrop-blur-lg
                translate-x-full transition-transform duration-300 md:hidden">
      <div class="flex flex-col pt-20 px-6 overflow-y-auto h-full">
        <NavMenu items={config.nav} />
      </div>
    </div>

    <main class="min-h-screen pt-24">
      <slot />
    </main>

    <footer class="neon-border border-x-0 border-b-0 mt-24 py-12">
      <div class="max-w-5xl mx-auto px-6">
        <div class="prose-footer max-w-lg mx-auto text-center">
          <Fragment set:html={marked.parse(config.footer.content || "")} />
        </div>
      </div>
    </footer>

    <script is:inline>
      /* Mobile hamburger */
      var html = document.documentElement;
      var hamburger = document.getElementById("hamburger");
      var drawer = document.getElementById("mobile-drawer");
      var hamIcon = document.getElementById("hamburger-icon");
      var closeIcon = document.getElementById("close-icon");
      if (hamburger && drawer) {
        hamburger.addEventListener("click", function() {
          var open = drawer.classList.toggle("translate-x-full");
          hamIcon.classList.toggle("hidden");
          closeIcon.classList.toggle("hidden");
          html.classList.toggle("overflow-hidden", !open);
        });
      }

      /* Scroll-triggered entrance animations */
      (function(){var e=document.querySelectorAll('[data-animate]');if(!e.length)return;if(window.matchMedia('(prefers-reduced-motion: reduce)').matches)return;var o=new IntersectionObserver(function(n){n.forEach(function(n){if(n.isIntersecting){n.target.classList.add('observed');o.unobserve(n.target)}})},{threshold:0.05});e.forEach(function(n){o.observe(n)})})();

      /* Mobile: tap submenu parent toggles, child links navigate normally */
      drawer && drawer.addEventListener("click", function(e) {
        var link = e.target.closest(".nav-group > .nav-link");
        if (!link) return;
        var group = link.parentElement;
        if (!group) return;
        if (!group.querySelector(":scope > .nav-submenu")) return;
        e.preventDefault();
        group.classList.toggle("nav-open");
      });
    </script>

    <script is:inline src="/scripts/features.js"></script>
  </body>
</html>
