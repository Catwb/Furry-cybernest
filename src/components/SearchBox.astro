<div id="search-overlay"
     class="fixed inset-0 z-[100] hidden flex-col items-center pt-[15vh] px-4"
     style="background:rgba(0,0,0,0.6)">
  <div class="w-full max-w-xl bg-[var(--color-card)] rounded-2xl neon-border overflow-hidden">
    <div class="flex items-center gap-3 px-5 py-4 border-b border-[var(--color-border)]">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-text)]/30 shrink-0">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
      </svg>
      <input id="search-input" type="text" placeholder="搜索文章、章节…"
             class="flex-1 bg-transparent border-none outline-none text-sm text-[var(--color-text)] placeholder:text-[var(--color-text)]/30" />
      <button id="search-close" class="text-[var(--color-text)]/30 hover:text-[var(--color-text)]/70 transition-colors text-lg leading-none" aria-label="关闭搜索">&times;</button>
    </div>
    <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2"></div>
  </div>
</div>

<script is:inline>
(function() {
  var overlay = document.getElementById("search-overlay");
  var input = document.getElementById("search-input");
  var results = document.getElementById("search-results");
  var closeBtn = document.getElementById("search-close");
  var index = null;

  function openSearch() {
    overlay.classList.remove("hidden");
    overlay.classList.add("flex");
    setTimeout(function() { if (input) input.focus(); }, 100);
    if (!index) loadIndex();
  }

  function closeSearch() {
    overlay.classList.add("hidden");
    overlay.classList.remove("flex");
    if (input) input.value = "";
    if (results) results.innerHTML = "";
  }

  function loadIndex() {
    fetch("/search.json").then(function(r) { return r.json(); }).then(function(data) {
      index = data;
    }).catch(function() {});
  }

  function doSearch(q) {
    if (!results) return;
    if (!q || !index) {
      results.innerHTML = "";
      return;
    }
    var lowered = q.toLowerCase();
    var hits = index.filter(function(item) {
      return item.title.toLowerCase().includes(lowered) || item.description.toLowerCase().includes(lowered);
    });
    if (hits.length === 0) {
      results.innerHTML = '<div class="text-center py-10 text-sm text-[var(--color-text)]/30">没有找到相关内容</div>';
      return;
    }
    var html = "";
    hits.slice(0, 20).forEach(function(item) {
      html += '<a href="' + item.url + '" class="flex items-center gap-3 p-3 rounded-xl hover:bg-[var(--color-primary)]/5 transition-colors no-underline" onclick="closeSearch()">';
      html += '  <span class="text-[10px] px-1.5 py-0.5 rounded-full neon-border text-[var(--color-text)]/40 shrink-0">' + item.type + '</span>';
      html += '  <div class="min-w-0 flex-1">';
      html += '    <p class="text-sm text-[var(--color-text)]/80 truncate">' + escapeHtml(item.title) + '</p>';
      html += '    <p class="text-xs text-[var(--color-text)]/35 truncate">' + escapeHtml(item.description) + '</p>';
      html += '  </div>';
      html += '</a>';
    });
    results.innerHTML = html;
  }

  function escapeHtml(s) {
    var d = document.createElement("div");
    d.textContent = s;
    return d.innerHTML;
  }

  if (input) input.addEventListener("input", function() { doSearch(input.value); });
  if (closeBtn) closeBtn.addEventListener("click", closeSearch);
  overlay.addEventListener("click", function(e) { if (e.target === overlay) closeSearch(); });
  document.addEventListener("keydown", function(e) { if (e.key === "Escape") closeSearch(); });

  // Expose toggle for nav buttons
  window._openSearch = openSearch;
  window._closeSearch = closeSearch;
})();
</script>
