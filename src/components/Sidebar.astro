---
import { getCollection } from "astro:content";
import config from "virtual:site-config";

const allPosts = (await getCollection("blog")).filter((p) => !p.data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const totalWords = allPosts.reduce((sum, p) => sum + (p.body ? p.body.trim().length : 0), 0);

interface CatNode {
  name: string;
  full: string;
  count: number;
  children: Map<string, CatNode>;
}

const root = new Map<string, CatNode>();
for (const p of allPosts) {
  const cats = p.data.categories;
  if (!cats || cats.length === 0) continue;
  let map = root;
  let fullPath = "";
  for (let i = 0; i < cats.length; i++) {
    const name = cats[i];
    fullPath = fullPath ? `${fullPath}/${name}` : name;
    if (!map.has(name)) {
      map.set(name, { name, full: fullPath, count: 0, children: new Map() });
    }
    const node = map.get(name)!;
    node.count++;
    map = node.children;
  }
}

function sorted(nodes: Map<string, CatNode>): CatNode[] {
  return [...nodes.values()].sort((a, b) => b.count - a.count);
}

// Archive grouping
const byYear = new Map<number, Map<number, number>>();
for (const p of allPosts) {
  const d = p.data.pubDate;
  const y = d.getFullYear();
  const m = d.getMonth() + 1;
  if (!byYear.has(y)) byYear.set(y, new Map());
  const months = byYear.get(y)!;
  months.set(m, (months.get(m) || 0) + 1);
}
const sortedYears = [...byYear.entries()].sort((a, b) => b[0] - a[0]);

// Social icon mapping
const socialIcons: Record<string, string> = {
  github: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>`,
  twitter: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  weibo: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M10.098 20.323c-3.977.391-7.414-1.406-7.672-4.02-.259-2.609 2.759-5.047 6.74-5.441 3.979-.394 7.413 1.404 7.671 4.018.259 2.6-2.759 5.049-6.739 5.443z"/><path d="M21.786 10.182a3.6 3.6 0 0 0-.717-1.036 3.716 3.716 0 0 0-1.099-.755 4.512 4.512 0 0 0-.752-.273q.008.13.008.262a3.674 3.674 0 0 1-.359 1.6 3.678 3.678 0 0 1-.982 1.316 3.704 3.704 0 0 1-1.408.794 3.7 3.7 0 0 1-1.609.066 3.7 3.7 0 0 1-.539-.164q.196.086.406.152c.478.153.98.227 1.482.222a3.69 3.69 0 0 0 1.593-.374 3.69 3.69 0 0 0 1.26-1.038 3.68 3.68 0 0 0 .728-1.515 3.68 3.68 0 0 0 .028-1.072 3.68 3.68 0 0 0 1.958-.217 2.654 2.654 0 0 0 .393-.198z"/></svg>`,
  bilibili: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.622.018-1.156.231-1.6.64-.444.409-.666.942-.666 1.6v6.453c0 .658.222 1.191.666 1.6.444.409.978.622 1.6.64h13.334c.622-.018 1.156-.231 1.6-.64.444-.409.666-.942.666-1.6V9.48c0-.658-.222-1.191-.666-1.6-.444-.409-.978-.622-1.6-.64zM8.107 10.96c.249-.267.573-.4.973-.4s.724.133.973.4l2.347 2.347 2.347-2.347c.249-.267.573-.4.973-.4s.724.133.973.4c.267.249.4.573.4.973s-.133.724-.4.973l-3.32 3.32c-.249.267-.573.4-.973.4s-.724-.133-.973-.4l-3.32-3.32c-.267-.249-.4-.573-.4-.973s.133-.724.4-.973z"/></svg>`,
  pencil: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>`,
};

const iconNames: Record<string, string> = {
  github: "GitHub", twitter: "Twitter", weibo: "微博", bilibili: "B站", pencil: "Pixiv",
};
---

<aside class="space-y-6">
  <!-- Author Card -->
  {config.homepage.sidebar.author && (
    <div class="rounded-xl neon-border p-5 bg-white text-center">
      <div class="w-16 h-16 rounded-full mx-auto mb-3
                  bg-gradient-to-br from-[var(--color-primary)]/20 to-[var(--color-accent)]/10
                  flex items-center justify-center text-[var(--color-primary)] text-xl font-bold">
        {config.site.author.charAt(0)}
      </div>
      <p class="font-heading text-sm text-[var(--color-text)]">{config.site.author}</p>
      <p class="text-xs text-[var(--color-text)]/40 mt-1 mb-4">{config.site.description}</p>
      <div class="flex items-center justify-center gap-4 mb-4 text-xs">
        <div>
          <p class="font-heading text-sm text-[var(--color-primary)]">{allPosts.length}</p>
          <p class="text-[var(--color-text)]/30 text-[10px]">文章</p>
        </div>
        <div class="w-px h-8 bg-[var(--color-border)]" />
        <div>
          <p class="font-heading text-sm text-[var(--color-primary)]">{root.size}</p>
          <p class="text-[var(--color-text)]/30 text-[10px]">分类</p>
        </div>
        <div class="w-px h-8 bg-[var(--color-border)]" />
        <div>
          <p class="font-heading text-sm text-[var(--color-primary)]">{sortedYears.length}</p>
          <p class="text-[var(--color-text)]/30 text-[10px]">年份</p>
        </div>
      </div>
      {config.social.length > 0 && (
        <div class="flex items-center justify-center gap-2">
          {config.social.map((s) => (
            <a href={s.url} target="_blank" rel="noopener"
               class="w-7 h-7 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center
                      text-[var(--color-primary)]/60 hover:bg-[var(--color-primary)] hover:text-white
                      transition-all duration-300"
               title={iconNames[s.icon] || s.name}>
              <Fragment set:html={socialIcons[s.icon] || ""} />
            </a>
          ))}
        </div>
      )}
    </div>
  )}

  <!-- Recent Posts -->
  {config.homepage.sidebar.recentPosts && sortedPosts.length > 0 && (
    <div class="rounded-xl neon-border p-5 bg-white">
      <p class="font-heading text-sm text-[var(--color-text)] mb-3">最新文章</p>
      <div class="space-y-3">
        {sortedPosts.slice(0, 5).map((p) => (
          <a href={`/posts/${p.data.abbrlink || p.slug}`}
             class="block no-underline group">
            <p class="text-xs text-[var(--color-text)]/80 group-hover:text-[var(--color-secondary)]
                      transition-colors duration-200 line-clamp-1">
              {p.data.title}
            </p>
            <time class="text-[10px] text-[var(--color-text)]/25 mt-0.5 block">
              {p.data.pubDate.toLocaleDateString("zh-CN")}
            </time>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Categories -->
  {config.homepage.sidebar.categories && root.size > 0 && (
    <div class="rounded-xl neon-border p-5 bg-white">
      <div class="flex items-center justify-between mb-3">
        <p class="font-heading text-sm text-[var(--color-text)]">分类</p>
        <a href="/blog/categories"
           class="text-[10px] text-[var(--color-primary)] hover:text-[var(--color-secondary)]
                  transition-colors no-underline">更多</a>
      </div>
      <div class="space-y-1.5">
        {sorted(root).slice(0, 8).map((node) => (
          <>
            <a href={`/blog/categories/${node.full}`}
               class="flex items-center justify-between text-xs no-underline
                      text-[var(--color-text)]/60 hover:text-[var(--color-secondary)] transition-colors group">
              <span class="group-hover:text-[var(--color-secondary)] transition-colors">{node.name}</span>
              <span class="text-[var(--color-text)]/25 text-[10px]">{node.count}</span>
            </a>
            {sorted(node.children).slice(0, 3).map((child) => (
              <a href={`/blog/categories/${child.full}`}
                 class="flex items-center justify-between text-xs no-underline pl-3
                        text-[var(--color-text)]/40 hover:text-[var(--color-secondary)] transition-colors group">
                <span class="group-hover:text-[var(--color-secondary)] transition-colors">/ {child.name}</span>
                <span class="text-[var(--color-text)]/25 text-[10px]">{child.count}</span>
              </a>
            ))}
          </>
        ))}
      </div>
    </div>
  )}

  <!-- Archives -->
  {config.homepage.sidebar.archives && sortedYears.length > 0 && (
    <div class="rounded-xl neon-border p-5 bg-white">
      <div class="flex items-center justify-between mb-3">
        <p class="font-heading text-sm text-[var(--color-text)]">归档</p>
        <a href="/archive"
           class="text-[10px] text-[var(--color-primary)] hover:text-[var(--color-secondary)]
                  transition-colors no-underline">更多</a>
      </div>
      <div class="space-y-1.5">
        {sortedYears.slice(0, 6).map(([year, months]) => (
          <div>
            <p class="text-xs text-[var(--color-text)]/40 mb-1">{year}</p>
            <div class="space-y-1 pl-2">
              {[...months.entries()].sort((a, b) => b[0] - a[0]).slice(0, 3).map(([month, count]) => (
                <a href={`/archive#${year}-${String(month).padStart(2, "0")}`}
                   class="flex items-center justify-between text-[10px] no-underline
                          text-[var(--color-text)]/40 hover:text-[var(--color-secondary)] transition-colors">
                  <span>{month} 月</span>
                  <span class="text-[var(--color-text)]/20">{count} 篇</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Site Info -->
  {config.homepage.sidebar.siteInfo && (
    <div class="rounded-xl neon-border p-5 bg-white">
      <p class="font-heading text-sm text-[var(--color-text)] mb-3">站点信息</p>
      <div class="space-y-1.5 text-xs">
        <div class="flex items-center justify-between text-[var(--color-text)]/50">
          <span>文章总数</span>
          <span class="text-[var(--color-text)]/70">{allPosts.length}</span>
        </div>
        {totalWords > 0 && (
          <div class="flex items-center justify-between text-[var(--color-text)]/50">
            <span>总字数</span>
            <span class="text-[var(--color-text)]/70">{totalWords >= 1000 ? `${(totalWords / 1000).toFixed(1)}k` : totalWords}</span>
          </div>
        )}
        {sortedPosts.length > 0 && (
          <div class="flex items-center justify-between text-[var(--color-text)]/50">
            <span>最后更新</span>
            <span class="text-[var(--color-text)]/70">{sortedPosts[0].data.pubDate.toLocaleDateString("zh-CN")}</span>
          </div>
        )}
        <div class="pt-2 mt-2 border-t border-[var(--color-border)]">
          <div class="flex items-center justify-between text-[var(--color-text)]/50">
            <span>运行天数</span>
            <span class="text-[var(--color-text)]/70">
              {Math.floor((Date.now() - (sortedPosts.length > 0 ? sortedPosts[sortedPosts.length - 1].data.pubDate.getTime() : Date.now())) / 86400000) || 1}
            </span>
          </div>
        </div>
      </div>
    </div>
  )}
</aside>
