---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

function postUrl(post: { data: { abbrlink?: string }; slug: string }) {
  return post.data.abbrlink || post.slug;
}

const posts = (await getCollection("blog")).filter((p) => !p.data.draft);

const tagMap = new Map<string, typeof posts>();
for (const p of posts) {
  for (const tag of p.data.tags) {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push(p);
  }
}
const tags = [...tagMap.entries()].sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout title="标签">
  <div class="max-w-4xl mx-auto px-6 py-8">
    <h1 data-animate class="font-heading text-3xl neon-text-primary mb-2">标签</h1>
    <p data-animate class="text-sm text-[var(--color-text)]/50 mb-10">
      共 {tags.length} 个标签
    </p>

    {
      tags.length === 0 && (
        <div class="text-center py-20 text-sm text-[var(--color-text)]/30">
          还没有标签
        </div>
      )
    }

    <div class="flex flex-wrap gap-3">
      {tags.map(([tag, posts], i) => (
        <a href={`/blog/tags/${encodeURIComponent(tag)}`}
           data-animate style="transition-delay:{i * 0.04}s"
            class="group px-5 py-2.5 rounded-xl neon-border no-underline
                   bg-[var(--color-bg)]/40 hover:neon-glow-primary
                   transition-lift hover:-translate-y-0.5">
          <span class="text-sm text-[var(--color-text)]/80 group-hover:text-[var(--color-secondary)]
                       transition-colors duration-200">{tag}</span>
          <span class="ml-2 text-xs text-[var(--color-text)]/30">{posts.length}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
