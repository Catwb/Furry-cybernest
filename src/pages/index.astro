---
import BaseLayout from "../layouts/BaseLayout.astro";
import config from "virtual:site-config";

const { homepage } = config;
---

<BaseLayout>
  <div class="cyber-grid min-h-screen overflow-x-hidden">
    <!-- Hero -->
    <section class="relative flex flex-col items-center justify-center text-center px-6 pt-24 pb-16">
      <div data-animate class="max-w-5xl mx-auto animate-fade-in">
        <h1 class="font-heading text-5xl md:text-7xl neon-text-primary mb-6 leading-tight break-words
                   [text-shadow:0_0_20px_var(--color-primary),0_0_40px_var(--color-glow)]">
          {homepage.hero.title}
        </h1>
        {homepage.hero.subtitle && (
          <p class="text-lg md:text-xl text-[var(--color-text)]/70 mb-10
                    max-w-xl mx-auto leading-relaxed">
            {homepage.hero.subtitle}
          </p>
        )}
        <a href="/blog"
           class="inline-block px-8 py-3 rounded-full neon-border-primary
                  text-[var(--color-primary)] hover:bg-[var(--color-primary)] hover:text-white
                  transition-all duration-300 neon-glow-primary font-heading text-sm
                  hover:neon-glow-accent">
          探索故事
        </a>
      </div>

      <!-- Decorative glowing orb -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
                  w-96 h-96 rounded-full opacity-10 pointer-events-none"
           style="background: radial-gradient(circle, var(--color-primary) 0%, transparent 70%)">
      </div>
    </section>

    <!-- Featured Posts -->
    <section class="max-w-5xl mx-auto px-6 py-16">
      <h2 data-animate class="font-heading text-2xl neon-text-secondary mb-8 text-center">精选故事</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          Array.from({ length: homepage.featuredPosts }).map((_, i) => (
            <a href={i === 0 ? "/blog/cyber-forest" : "/blog"}
               data-animate style="transition-delay:{i * 0.1}s"
               class="group block p-6 rounded-xl neon-border bg-[var(--color-bg)]/60
                       hover:neon-glow-primary transition-all duration-300
                       hover:-translate-y-0.5 no-underline">
              <div class="w-full aspect-video rounded-lg mb-4
                          bg-gradient-to-br from-[var(--color-primary)]/20 to-[var(--color-secondary)]/10
                          flex items-center justify-center text-[var(--color-text)]/30 text-sm">
                故事封面
              </div>
              <h3 class="font-heading text-base text-[var(--color-text)] group-hover:neon-text-primary
                        transition-all duration-300 mb-2">
                {i === 0 ? "赛博森林的兽" : `故事 ${i + 1}`}
              </h3>
              <p class="text-xs text-[var(--color-text)]/50 line-clamp-2">
                {i === 0
                  ? "在霓虹闪烁的赛博森林深处，一只银狐苏醒于数据洪流之中..."
                  : "故事摘要加载中..."}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Character Spotlight -->
    {
      homepage.showCharacterSpotlight && (
        <section data-animate class="max-w-5xl mx-auto px-6 py-16">
          <div class="relative rounded-2xl neon-border overflow-hidden
                      bg-gradient-to-r from-[var(--color-primary)]/10 to-[var(--color-secondary)]/5
                      p-8 md:p-12 flex flex-col md:flex-row items-center gap-8">
            <div class="w-40 h-40 md:w-52 md:h-52 rounded-full neon-glow-accent flex-shrink-0
                        bg-gradient-to-br from-[var(--color-accent)]/20 to-[var(--color-primary)]/10
                        flex items-center justify-center text-[var(--color-text)]/20 text-sm">
              兽设头像
            </div>
            <div>
              <span class="text-xs neon-text-accent font-heading tracking-widest">SPOTLIGHT</span>
              <h2 class="font-heading text-2xl mt-1 mb-3 neon-text-primary">角色 spotlight</h2>
              <p class="text-sm text-[var(--color-text)]/60 leading-relaxed max-w-md">
                这里是你的兽设角色卡片。名字、种族、故事背景可以放在这里。
                所有内容均可通过 <code class="text-[var(--color-secondary)]">site.config.ts</code> 配置。
              </p>
            </div>
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
