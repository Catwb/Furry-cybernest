---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import { getCollection } from "astro:content";
import config from "virtual:site-config";

function postUrl(post: { data: { abbrlink?: string }; slug: string }) {
  return post.data.abbrlink || post.slug;
}

const perPage = config.homepage.postsPerPage;
const allPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const totalPages = Math.ceil(allPosts.length / perPage);
const posts = allPosts.slice(0, perPage).map((p) => ({
  ...p,
  wordCount: p.body ? p.body.trim().length : 0,
  readingTime: Math.max(1, Math.ceil((p.body ? p.body.trim().length : 0) / 500)),
}));
const showSidebar = config.homepage.sidebar.author || config.homepage.sidebar.categories || config.homepage.sidebar.recentPosts || config.homepage.sidebar.archives || config.homepage.sidebar.siteInfo;
---

<BaseLayout>
  {config.homepage.hero.show && config.homepage.hero.background && (
    <section class="relative w-full h-screen flex flex-col items-center justify-center text-center px-6
                    overflow-hidden">
      <div data-animate class="animate-fade-in relative z-10">
        <h1 class="font-heading text-5xl md:text-7xl text-white mb-6 leading-tight
                   [text-shadow:0_2px_20px_rgba(0,0,0,0.5)]">
          {config.homepage.hero.title}
        </h1>
        {config.homepage.hero.subtitle && (
          <p class="text-lg md:text-xl text-white/80 mb-8 max-w-xl mx-auto
                    [text-shadow:0_1px_10px_rgba(0,0,0,0.4)]">
            {config.homepage.hero.subtitle}
          </p>
        )}
      </div>
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce text-white/40">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
    </section>
  )}

  <div id="main-content" class="max-w-6xl mx-auto px-6 py-8">
    {config.homepage.hero.show && !config.homepage.hero.background && (
      <section data-animate class="text-center mb-12">
        <h1 class="font-heading text-4xl md:text-5xl neon-text-primary mb-4 leading-tight">
          {config.homepage.hero.title}
        </h1>
        {config.homepage.hero.subtitle && (
          <p class="text-base text-[var(--color-text)]/60 max-w-lg mx-auto">
            {config.homepage.hero.subtitle}
          </p>
        )}
      </section>
    )}

    <div class={`flex flex-col ${showSidebar ? 'md:flex-row' : ''} gap-8`}>
      <div class={showSidebar ? 'md:w-3/4' : 'w-full'}>
        <div class="flex flex-col gap-5">
          {
            posts.map((post, i) => {
              const d = post.data.pubDate;
              const month = d.toLocaleDateString("zh-CN", { month: 'long' });
              const year = d.getFullYear();
              return (
              <a href={`/posts/${postUrl(post)}`}
                 data-animate style={`transition-delay:${i * 0.04}s`}
                 class="group flex flex-col sm:flex-row items-stretch rounded-xl neon-border overflow-hidden no-underline
                        bg-[var(--color-card)] hover:neon-glow-primary
                        transition-lift hover:-translate-y-0.5">
                <!-- Date column -->
                <div class="flex sm:flex-col items-center sm:justify-center gap-1 sm:gap-0
                            px-4 sm:px-3 py-2 sm:py-4 sm:min-w-[4.5rem] shrink-0
                            border-b sm:border-b-0 sm:border-r border-[var(--color-border)]">
                  <span class="text-lg sm:text-2xl font-heading leading-none text-[var(--color-primary)]">
                    {d.getDate()}
                  </span>
                  <span class="text-[10px] text-[var(--color-text)]/40 sm:mt-1.5 whitespace-nowrap">
                    {month}{year}
                  </span>
                </div>
                {post.data.cover && (
                  <div class="sm:w-44 shrink-0 overflow-hidden aspect-video sm:aspect-auto">
                    <img src={post.data.cover} alt={post.data.title}
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  </div>
                )}
                <div class="flex flex-col flex-1 min-w-0 px-5 py-4">
                  <div class="flex items-center gap-2 mb-2 flex-wrap">
                    {post.data.categories.length > 0 && post.data.categories.map((cat) => (
                      <span class="text-[10px] px-2 py-0.5 rounded-full neon-border text-[var(--color-primary)]/70 bg-[var(--color-primary)]/5">
                        {cat}
                      </span>
                    ))}
                  </div>
                  <h2 class="font-heading text-base text-[var(--color-text)] group-hover:text-[var(--color-secondary)]
                             transition-colors duration-200 mb-1.5 line-clamp-1">
                    {post.data.title}
                  </h2>
                  {post.data.description && (
                    <p class="text-sm text-[var(--color-text)]/45 line-clamp-2 mb-3">
                      {post.data.description}
                    </p>
                  )}
                  <div class="flex items-center gap-3 text-xs text-[var(--color-text)]/30 mt-auto">
                    <span>{post.wordCount} 字</span>
                    <span class="w-1 h-1 rounded-full bg-[var(--color-text)]/20"></span>
                    <span>{post.readingTime} 分钟</span>
                  </div>
                </div>
              </a>
              );
            })
          }
        </div>

        {posts.length === 0 && (
          <div class="text-center py-20 text-sm text-[var(--color-text)]/30">
            还没有文章
          </div>
        )}

        {totalPages > 1 && (
          <nav class="flex items-center justify-center gap-2 mt-10 text-sm">
            <span class="text-[var(--color-primary)] font-heading">1</span>
            {Array.from({ length: totalPages - 1 }, (_, i) => (
              <a href={`/page/${i + 2}`}
                 class="text-[var(--color-text)]/40 hover:text-[var(--color-secondary)] transition-colors no-underline px-2 py-1">
                {i + 2}
              </a>
            ))}
          </nav>
        )}
      </div>

      {showSidebar && (
        <div class="md:w-1/4">
          <Sidebar />
        </div>
      )}
    </div>
  </div>
</BaseLayout>
