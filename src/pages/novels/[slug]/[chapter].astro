---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const chapters = (await getCollection("chapters")).filter((c) => !c.data.draft);
  return chapters.map((ch) => ({
    params: { slug: ch.data.novel, chapter: String(ch.data.chapter) },
  }));
}

const { slug, chapter } = Astro.params;
const chapterNum = Number(chapter);

const novel = (await getCollection("novels")).find((n) => n.slug === slug);
if (!novel) return Astro.redirect("/404");

const allChapters = (await getCollection("chapters"))
  .filter((c) => c.data.novel === slug && !c.data.draft)
  .sort((a, b) => a.data.chapter - b.data.chapter);

const current = allChapters.find((c) => c.data.chapter === chapterNum);
if (!current) return Astro.redirect(`/novels/${slug}`);

const prev = allChapters.find((c) => c.data.chapter === chapterNum - 1);
const next = allChapters.find((c) => c.data.chapter === chapterNum + 1);
const { Content } = await current.render();
---

<BaseLayout title={`${current.data.title} · ${novel.data.title}`}>
  <div class="max-w-3xl mx-auto px-6 py-8">
    <!-- Top nav -->
    <div class="flex items-center justify-between mb-8 text-sm">
      <a href={`/novels/${slug}`}
         class="flex items-center gap-1 text-[var(--color-text)]/40 hover:text-[var(--color-secondary)]
                transition-colors duration-300 no-underline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6" />
        </svg>
        {novel.data.title}
      </a>
      <span class="text-xs text-[var(--color-text)]/30">
        第 {chapterNum} 章
      </span>
    </div>

    <!-- Chapter title -->
    <h1 class="font-heading text-2xl neon-text-primary mb-2">{current.data.title}</h1>
    {current.data.pubDate && (
      <p class="text-xs text-[var(--color-text)]/30 mb-8">
        {current.data.pubDate.toLocaleDateString("zh-CN")}
      </p>
    )}

    <!-- Content -->
    <div data-animate class="prose-neon max-w-none">
      <Content />
    </div>

    <!-- Bottom nav -->
    <div class="grid grid-cols-2 gap-4 mt-12 pt-8">
      <a href={prev ? `/novels/${slug}/${prev.data.chapter}` : "#"}
          class={`flex items-center gap-3 px-5 py-4 rounded-xl neon-border
                  transition-lift no-underline group
                  ${prev ? "hover:neon-glow-primary hover:-translate-x-1 cursor-pointer" : "opacity-30 pointer-events-none"}`}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="text-[var(--color-text)]/40 shrink-0">
          <polyline points="15 18 9 12 15 6" />
        </svg>
        <div class="text-left min-w-0">
          <p class="text-xs text-[var(--color-text)]/30">上一章</p>
          <p class="text-sm text-[var(--color-text)]/70 truncate
                     group-hover:neon-text-primary transition-all duration-300">
            {prev ? prev.data.title : "没有了"}
          </p>
        </div>
      </a>

      <a href={next ? `/novels/${slug}/${next.data.chapter}` : "#"}
          class={`flex items-center justify-end gap-3 px-5 py-4 rounded-xl neon-border
                  transition-lift no-underline group text-right
                  ${next ? "hover:neon-glow-primary hover:translate-x-1 cursor-pointer" : "opacity-30 pointer-events-none"}`}>
        <div class="min-w-0">
          <p class="text-xs text-[var(--color-text)]/30">下一章</p>
          <p class="text-sm text-[var(--color-text)]/70 truncate
                     group-hover:neon-text-primary transition-all duration-300">
            {next ? next.data.title : "没有了"}
          </p>
        </div>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="text-[var(--color-text)]/40 shrink-0">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </a>
    </div>
  </div>
</BaseLayout>