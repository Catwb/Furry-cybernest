---
import BaseLayout from "../layouts/BaseLayout.astro";
import config from "virtual:site-config";
---

<BaseLayout title="联系">
  <div class="max-w-3xl mx-auto px-6 py-8">
    <h1 class="font-heading text-3xl neon-text-primary mb-2">联系</h1>
    <p class="text-sm text-[var(--color-text)]/50 mb-10">随时欢迎交流</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Contact Form -->
      <div class="neon-border rounded-xl p-6 bg-[var(--color-bg)]/40">
        <h2 class="font-heading text-lg neon-text-secondary mb-4">发送消息</h2>
        <form class="space-y-4" onsubmit="return false">
          <div>
            <label class="block text-xs text-[var(--color-text)]/60 mb-1" for="name">称呼</label>
            <input id="name" type="text"
                   class="w-full px-4 py-2 rounded-lg bg-[var(--color-bg)] text-[var(--color-text)]
                          neon-border focus:neon-border-secondary focus:outline-none
                          transition-all duration-300 text-sm" />
          </div>
          <div>
            <label class="block text-xs text-[var(--color-text)]/60 mb-1" for="email">邮箱</label>
            <input id="email" type="email"
                   class="w-full px-4 py-2 rounded-lg bg-[var(--color-bg)] text-[var(--color-text)]
                          neon-border focus:neon-border-secondary focus:outline-none
                          transition-all duration-300 text-sm" />
          </div>
          <div>
            <label class="block text-xs text-[var(--color-text)]/60 mb-1" for="message">消息</label>
            <textarea id="message" rows="4"
                      class="w-full px-4 py-2 rounded-lg bg-[var(--color-bg)] text-[var(--color-text)]
                             neon-border focus:neon-border-secondary focus:outline-none
                             transition-all duration-300 text-sm resize-none"></textarea>
          </div>
          <button type="submit"
                  class="w-full px-6 py-2.5 rounded-full neon-border-primary
                         text-[var(--color-primary)] hover:bg-[var(--color-primary)] hover:text-white
                         transition-all duration-300 text-sm font-heading">
            发送
          </button>
        </form>
      </div>

      <!-- Social Links -->
      <div class="neon-border rounded-xl p-6 bg-[var(--color-bg)]/40">
        <h2 class="font-heading text-lg neon-text-secondary mb-4">社交平台</h2>
        <div class="space-y-3">
          {
            config.social.map((s) => (
              <a href={s.url} target="_blank" rel="noopener noreferrer"
                 class="flex items-center gap-3 px-4 py-3 rounded-lg
                        neon-border text-sm text-[var(--color-text)]/70
                        hover:neon-glow-secondary hover:text-[var(--color-secondary)]
                        transition-all duration-300 no-underline">
                <span class="w-8 h-8 flex items-center justify-center rounded-full
                            neon-border text-xs text-[var(--color-secondary)]">
                  {s.name.slice(0, 2)}
                </span>
                <span>{s.name}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
